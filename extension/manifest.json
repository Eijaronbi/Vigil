{
  "manifest_version": 3,
  "name": "Vigil - Message Monitor",
  "version": "1.0.1",
  "description": "Monitors WhatsApp Web, reads important messages aloud via Vigil dashboard",
  "permissions": ["storage", "alarms", "tts", "notifications"],
  "host_permissions": ["https://web.whatsapp.com/*", "http://localhost:8002/*", "https://*/*"],
  "background": {"service_worker": "background.js"},
  "content_scripts": [{
    "matches": ["https://web.whatsapp.com/*"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }],
  "action": {"default_popup": "popup.html", "default_title": "Vigil"},
  "icons": {"128": "icon.png"}
}
